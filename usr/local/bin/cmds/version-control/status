#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -uo pipefail

# Color codes for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# Logging functions
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Function to print usage information
show_usage() {
    cat << EOF
Usage: airlab vcs status [OPTIONS]

Display the status of repositories. Reads AIRLAB_REPO_FILE from the current
directory to compare each repo's current branch against the expected branch
defined in the YAML file.

Options:
  --help              Display this help message and exit
  --show-branch       Show the current branch of the repository

Examples:
  airlab vcs status
  airlab vcs status --show-branch

Note: This script uses the 'vcs' command to interact with the repository.
Note: Run this command from the directory containing AIRLAB_REPO_FILE.
EOF
}

check_repositories() {
    local base_dir=$1
    local yaml_file=$2

    python3 - "$base_dir" "$yaml_file" <<'PYEOF'
import sys
import os
import yaml

GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
NC     = "\033[0m"

base_dir  = sys.argv[1]
yaml_file = sys.argv[2]

with open(yaml_file, "r") as f:
    data = yaml.safe_load(f)

repos = set(data.get("repositories", {}).keys())

prefixes = set()
for repo in repos:
    parts = repo.split("/")
    for i in range(1, len(parts)):
        prefixes.add("/".join(parts[:i]))

missing = []
for repo in sorted(repos):
    if not os.path.isdir(os.path.join(base_dir, repo)):
        missing.append(repo)

extra = []

def walk(rel_path):
    abs_path = os.path.join(base_dir, rel_path) if rel_path else base_dir
    try:
        entries = sorted(os.listdir(abs_path))
    except PermissionError:
        return
    for entry in entries:
        if entry.startswith("."):
            continue
        entry_abs = os.path.join(abs_path, entry)
        if not os.path.isdir(entry_abs):
            continue
        child_rel = os.path.join(rel_path, entry) if rel_path else entry
        if child_rel in repos:
            continue
        elif child_rel in prefixes:
            walk(child_rel)
        else:
            extra.append(child_rel)

walk("")

if missing:
    print(f"{YELLOW}[MISSING]{NC} Repositories defined in YAML but not found on disk:")
    for m in missing:
        print(f"  - {m}")
else:
    print(f"{GREEN}[OK]{NC} All repositories from YAML exist on disk.")

if extra:
    print(f"{YELLOW}[EXTRA]{NC} Folders on disk but not defined in YAML:")
    for e in extra:
        print(f"  + {e}")
else:
    print(f"{GREEN}[OK]{NC} No extra folders found on disk.")

sys.exit(1 if missing or extra else 0)
PYEOF
}

check_branches() {
    local base_dir=$1
    local yaml_file=$2

    python3 - "$base_dir" "$yaml_file" <<'PYEOF'
import sys
import os
import subprocess
import yaml

RED    = "\033[0;31m"
GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
NC     = "\033[0m"

def git(repo_dir, *args, timeout=10):
    result = subprocess.run(
        ["git", "-C", repo_dir] + list(args),
        capture_output=True, text=True, timeout=timeout
    )
    return result.returncode, result.stdout.strip()

base_dir  = sys.argv[1]
yaml_file = sys.argv[2]

with open(yaml_file, "r") as f:
    data = yaml.safe_load(f)

repos = data.get("repositories", {})
has_issue = False

# Find the longest repo path for alignment
git_repos = [rp for rp in repos if repos[rp].get("type") == "git"]
max_len = max(max((len(rp) for rp in git_repos), default=0), len("Repository"))

BOLD = "\033[1m"
header = f"  {BOLD}{'Repository'.ljust(max_len)}  {'Branch':<20} | {'Remote':<16} | {'Working Tree':<16} | {'Submodules'}{NC}"
print(header)
print(f"  {'-' * max_len}  {'-' * 20}-+-{'-' * 16}-+-{'-' * 16}-+-{'-' * 10}")

for repo_path in sorted(git_repos):
    info = repos[repo_path]
    expected_version = str(info.get("version", ""))
    full_path = os.path.join(base_dir, repo_path)
    padded = repo_path.ljust(max_len)

    if not os.path.isdir(full_path):
        print(f"  {padded}  {RED}MISSING{NC}")
        has_issue = True
        continue

    flags = []

    # --- Branch ---
    try:
        _, current_branch = git(full_path, "rev-parse", "--abbrev-ref", "HEAD")
    except Exception:
        print(f"  {padded}  {RED}error: cannot read branch{NC}")
        has_issue = True
        continue

    if current_branch == expected_version:
        flags.append(f"{GREEN}{current_branch}{NC}")
    else:
        flags.append(f"{RED}{current_branch}{NC} (expected {GREEN}{expected_version}{NC})")
        has_issue = True

    # --- Remote sync ---
    git(full_path, "fetch", "--quiet", timeout=30)
    rc, _ = git(full_path, "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}")
    if rc != 0:
        flags.append(f"{YELLOW}no upstream{NC}")
    else:
        _, rev_list = git(full_path, "rev-list", "--left-right", "--count", "HEAD...@{u}")
        try:
            ahead, behind = int(rev_list.split()[0]), int(rev_list.split()[1])
        except (ValueError, IndexError):
            ahead, behind = 0, 0
        if ahead == 0 and behind == 0:
            flags.append(f"{GREEN}up to date{NC}")
        else:
            sync_parts = []
            if ahead:  sync_parts.append(f"{YELLOW}{ahead} ahead{NC}")
            if behind: sync_parts.append(f"{YELLOW}{behind} behind{NC}")
            flags.append(", ".join(sync_parts))

    # --- Dirty working tree ---
    _, status_output = git(full_path, "status", "--porcelain")
    if status_output:
        n_staged = n_unstaged = n_untracked = 0
        for line in status_output.splitlines():
            if len(line) < 2: continue
            x, y = line[0], line[1]
            if x == "?" and y == "?": n_untracked += 1
            else:
                if x not in (" ", "?"): n_staged += 1
                if y not in (" ", "?"): n_unstaged += 1
        dirty_parts = []
        if n_staged:    dirty_parts.append(f"{n_staged}S")
        if n_unstaged:  dirty_parts.append(f"{n_unstaged}M")
        if n_untracked: dirty_parts.append(f"{n_untracked}?")
        flags.append(f"{RED}dirty({'/'.join(dirty_parts)}){NC}")
        has_issue = True
    else:
        flags.append(f"{GREEN}clean{NC}")

    # --- Submodules ---
    _, sub_status = git(full_path, "submodule", "status", "--recursive")
    if sub_status:
        n_mod = sum(1 for l in sub_status.splitlines() if l.strip().startswith("+"))
        n_uninit = sum(1 for l in sub_status.splitlines() if l.strip().startswith("-"))
        if n_mod or n_uninit:
            sub_parts = []
            if n_mod:    sub_parts.append(f"{n_mod} modified")
            if n_uninit: sub_parts.append(f"{n_uninit} uninit")
            flags.append(f"{YELLOW}sub({'/'.join(sub_parts)}){NC}")
            has_issue = True

    print(f"  {padded}  {' | '.join(flags)}")

sys.exit(1 if has_issue else 0)
PYEOF
}

main() {

    SHOW_BRANCH=false

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --show-branch)
                SHOW_BRANCH=true
                ;;
            --help)
                show_usage
                exit 0
                ;;
            *)
                log_error "Invalid option: $1"
                show_usage
                exit 1
                ;;
        esac
        shift
    done

    # Read AIRLAB_REPO_FILE from PWD
    local marker_file="$PWD/AIRLAB_REPO_FILE"
    if [[ ! -f "$marker_file" ]]; then
        log_error "No AIRLAB_REPO_FILE found in current directory ($PWD)"
        exit 1
    fi
    local repo_name
    repo_name=$(cat "$marker_file")
    if [[ -z "$repo_name" ]]; then
        log_error "AIRLAB_REPO_FILE is empty"
        exit 1
    fi

    local yaml_file="$AIRLAB_PATH/version_control/$repo_name"
    if [[ ! -e "$yaml_file" ]]; then
        log_error "YAML file not found: $yaml_file"
        exit 1
    fi

    # Run vcs status first (preserves its own colors)
    log_info "vcs status output:"
    echo "---"
    if [[ "$SHOW_BRANCH" == true ]]; then
        vcs custom --args status --short --branch
    else
        vcs status
    fi
    echo "---"

    # Branch comparison against YAML
    echo
    log_info "Branch check against $repo_name:"
    check_branches "$PWD" "$yaml_file" || true

    # Directory structure check
    echo
    log_info "Directory check against $repo_name:"
    check_repositories "$PWD" "$yaml_file" || true
}

# Run main function
main "$@"
