#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -uo pipefail

# Color codes for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# Logging functions
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Function to print usage information
show_usage() {
    cat << EOF
Usage: airlab vcs init [OPTIONS]

Clone and set up repositories based on YAML configuration files. The YAML files live in version-control.

Options:
  --repo_file=FILE    Specify the YAML file containing repository information (default: repos.yaml).
  --path=DIR          Specify the directory to clone repositories into. 
                      If not specified, the directory from the YAML file is used.
  --all               Apply the operation to all YAML files in the version-control directory.
  --here              Re-initialize repos in the current directory using its AIRLAB_REPO_FILE.
  --here --check      Compare the current directory structure against AIRLAB_REPO_FILE's YAML.
  --here --from-scratch  Delete all YAML-defined repo folders and re-clone from scratch.
                         Only proceeds if --check finds no discrepancies (no missing, no extra).
  --entry=NAME        Only initialize the single repository entry NAME from the YAML file.
                      Valid with --repo_file or --here. Incompatible with --all, --check,
                      and --from-scratch. Errors out if NAME is not present in the YAML.
  --help              Display this help message and exit.

Dependencies:
  - git
  - python3 with vcstool module
  - python3 with PyYAML module

Example:
  airlab vcs init --repo_file=custom_repos.yaml --path=custom/path/

Description:
  This script clones and sets up repositories defined in YAML files using vcstool.
  It checks for required dependencies, creates the specified directory, copies the
  YAML file, and uses vcstool to clone and initialize the repositories.

Note: This script uses the 'vcs' command to interact with the repository.
Note: --all flag cannot be used with --repo_file or --path flags.
EOF
}

check_dependencies() {
    local deps=("git")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            log_error "Required dependency '$dep' is not installed."
            exit 1
        fi
    done

    # Check if python3 and PyYAML are available
    if ! python3 -c "import yaml" 2>/dev/null; then
        log_error "Python YAML module not found. Please install: pip3 install PyYAML"
        exit 1
    fi
}

extract_yaml_dir() {
    local yaml_file=$1

    # Use Python to extract the "dir" field from the YAML file
    python3 - <<EOF
import yaml
import sys

with open("$yaml_file", 'r') as file:
    data = yaml.safe_load(file)
    print(data.get("dir", ""))
EOF
}

check_repositories() {
    local base_dir=$1
    local yaml_file=$2

    python3 - "$base_dir" "$yaml_file" <<'PYEOF'
import sys
import os
import yaml

GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
RED    = "\033[0;31m"
NC     = "\033[0m"

base_dir  = sys.argv[1]
yaml_file = sys.argv[2]

with open(yaml_file, "r") as f:
    data = yaml.safe_load(f)

repos = set(data.get("repositories", {}).keys())

# Build the set of intermediate prefixes (parent components, not the repo keys themselves)
prefixes = set()
for repo in repos:
    parts = repo.split("/")
    for i in range(1, len(parts)):
        prefixes.add("/".join(parts[:i]))

# --- Situation 1: in YAML but not on disk ---
missing = []
for repo in sorted(repos):
    if not os.path.isdir(os.path.join(base_dir, repo)):
        missing.append(repo)

# --- Situation 2: on disk but not in YAML (pruned recursive walk) ---
extra = []

def walk(rel_path):
    abs_path = os.path.join(base_dir, rel_path) if rel_path else base_dir
    try:
        entries = sorted(os.listdir(abs_path))
    except PermissionError:
        return
    for entry in entries:
        # Skip hidden directories and regular files
        if entry.startswith("."):
            continue
        entry_abs = os.path.join(abs_path, entry)
        if not os.path.isdir(entry_abs):
            continue
        child_rel = os.path.join(rel_path, entry) if rel_path else entry
        if child_rel in repos:
            # Known repo leaf — expected, do not descend into repo internals
            continue
        elif child_rel in prefixes:
            # Known intermediate directory — descend
            walk(child_rel)
        else:
            # Unknown folder — report and prune
            extra.append(child_rel)

walk("")

# --- Print results ---
if missing:
    print(f"{YELLOW}[MISSING]{NC} Repositories defined in YAML but not found on disk:")
    for m in missing:
        print(f"  - {m}")
else:
    print(f"{GREEN}[OK]{NC} All repositories from YAML exist on disk.")

if extra:
    print(f"{YELLOW}[EXTRA]{NC} Folders on disk but not defined in YAML:")
    for e in extra:
        print(f"  + {e}")
else:
    print(f"{GREEN}[OK]{NC} No extra folders found on disk.")

sys.exit(1 if missing or extra else 0)
PYEOF
}

delete_yaml_repos() {
    local base_dir=$1
    local yaml_file=$2

    # Extract top-level directories to delete from the YAML repo keys.
    # For repos like "vcstool" and "old_tools/rosinstall", the top-level
    # entries are "vcstool" and "old_tools".
    local -a top_dirs
    mapfile -t top_dirs < <(python3 - "$yaml_file" <<'PYEOF'
import sys, yaml

with open(sys.argv[1]) as f:
    data = yaml.safe_load(f)

top = set()
for repo in data.get("repositories", {}).keys():
    top.add(repo.split("/")[0])

for d in sorted(top):
    print(d)
PYEOF
    )

    if [[ ${#top_dirs[@]} -eq 0 ]]; then
        log_warn "No repositories found in YAML file"
        return 0
    fi

    for dir_name in "${top_dirs[@]}"; do
        local target="$base_dir/$dir_name"

        # Safety: dir_name must not be empty
        if [[ -z "$dir_name" ]]; then
            log_error "Empty directory name from YAML, skipping"
            continue
        fi

        # Safety: target must be strictly under base_dir
        local resolved_base resolved_target
        resolved_base=$(realpath "$base_dir")
        resolved_target=$(realpath -m "$target")
        if [[ "$resolved_target" != "$resolved_base/"* ]]; then
            log_error "Refusing to delete '$resolved_target': not under '$resolved_base'"
            continue
        fi

        # Safety: refuse to delete system-critical paths
        case "$resolved_target" in
            /|/usr|/usr/*|/etc|/etc/*|/bin|/bin/*|/sbin|/sbin/*|/var|/var/*|/home|/tmp|/boot|/dev|/proc|/sys)
                log_error "Refusing to delete system path: $resolved_target"
                continue
                ;;
        esac

        if [[ -d "$target" ]]; then
            log_info "Deleting $target"
            rm -rf "$target"
        else
            log_warn "Directory not found, skipping: $target"
        fi
    done
}

check_duplicate_urls() {
    local yaml_file=$1

    python3 - "$yaml_file" <<'PYEOF'
import sys
import yaml
from collections import defaultdict

yaml_file = sys.argv[1]

with open(yaml_file, "r") as f:
    data = yaml.safe_load(f)

repos = (data or {}).get("repositories", {}) or {}

url_to_names = defaultdict(list)
for name, spec in repos.items():
    if spec and spec.get("type") == "git":
        url = spec.get("url")
        if url:
            url_to_names[url].append(name)

duplicates = {url: names for url, names in url_to_names.items() if len(names) > 1}

if duplicates:
    print(f"Duplicate git repository URL(s) found in {yaml_file}:", file=sys.stderr)
    for url, names in duplicates.items():
        print(f"  {url}", file=sys.stderr)
        for n in names:
            print(f"    - {n}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

filter_yaml_entry() {
    local yaml_file=$1
    local entry=$2
    local out_file=$3

    python3 - "$yaml_file" "$entry" "$out_file" <<'PYEOF'
import sys
import yaml

yaml_file, entry, out_file = sys.argv[1], sys.argv[2], sys.argv[3]

with open(yaml_file, "r") as f:
    data = yaml.safe_load(f) or {}

repos = data.get("repositories", {}) or {}
if entry not in repos:
    print(f"Entry '{entry}' not found in {yaml_file}.", file=sys.stderr)
    available = sorted(repos.keys())
    if available:
        print("Available entries:", file=sys.stderr)
        for name in available:
            print(f"  - {name}", file=sys.stderr)
    sys.exit(1)

data["repositories"] = {entry: repos[entry]}

with open(out_file, "w") as f:
    yaml.safe_dump(data, f, default_flow_style=False, sort_keys=False)
PYEOF
}

process_repository() {
    local repo_dir=$1
    local yaml_file=$2
    local entry=${3:-}
    local yaml_basename
    yaml_basename=$(basename "$yaml_file")

    if ! check_duplicate_urls "$yaml_file"; then
        log_error "Aborting: YAML file contains duplicate git repository URLs."
        exit 1
    fi

    # If an entry filter is specified, produce a filtered YAML containing only
    # that single repository entry, and import from it instead.
    local import_yaml="$yaml_file"
    local tmp_yaml=""
    if [[ -n "$entry" ]]; then
        tmp_yaml=$(mktemp --suffix=.yaml)
        if ! filter_yaml_entry "$yaml_file" "$entry" "$tmp_yaml"; then
            rm -f "$tmp_yaml"
            log_error "Aborting: entry '$entry' not found in $yaml_file."
            exit 1
        fi
        import_yaml="$tmp_yaml"
        log_info "Restricting initialization to single entry: $entry"
    fi

    log_info "Processing repository with YAML file: $yaml_file"
    mkdir -p "$repo_dir"

    # Copy the (possibly filtered) YAML file to the target directory
    cp "$import_yaml" "$repo_dir/$yaml_basename"

    # Initialize the workspace
    vcs import "$repo_dir" < "$repo_dir/$yaml_basename"
    cd "$repo_dir"
    vcs custom --git --args submodule update --init --recursive

    # Clean up the YAML file in the target directory and any tempfile
    rm -f "$repo_dir/$yaml_basename"
    [[ -n "$tmp_yaml" ]] && rm -f "$tmp_yaml"

    # Record which YAML file was used to initialize this directory.
    # Only write the marker on a full init (no --entry), since a partial
    # init does not fully describe the workspace.
    if [[ -z "$entry" ]]; then
        echo "$yaml_basename" > "$repo_dir/AIRLAB_REPO_FILE"
        log_info "Created AIRLAB_REPO_FILE in $repo_dir with content: $yaml_basename"
    fi
}

process_all_repositories() {
    local yaml_dir=$1
    local target_dir=$2

    for yaml_file in "$yaml_dir"/*.yaml; do
        [[ -e "$yaml_file" ]] || { log_warn "No YAML files found in $yaml_dir"; continue; }

        # Extract directory from YAML file or use provided path
        local yaml_dir_path
        yaml_dir_path=$(extract_yaml_dir "$yaml_file")
        local final_dir="${yaml_dir_path:-$target_dir}"

        process_repository "$AIRLAB_PATH/$final_dir" "$yaml_file"
    done
}

main() {
    # Check dependencies first
    check_dependencies

    REPO_NAME=repos.yaml
    REPO_DIR=""
    ALL=false
    HERE=false
    CHECK=false
    FROM_SCRATCH=false
    ENTRY=""

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo_file=*)
                REPO_NAME="${1#--repo_file=}"
                ;;
            --path=*)
                REPO_DIR="${1#--path=}"
                ;;
            --all)
                ALL=true
                ;;
            --here)
                HERE=true
                ;;
            --check)
                CHECK=true
                ;;
            --from-scratch)
                FROM_SCRATCH=true
                ;;
            --entry=*)
                ENTRY="${1#--entry=}"
                ;;
            --help)
                show_usage
                exit 0
                ;;
            *)
                log_error "Invalid option: $1"
                show_usage
                exit 1
                ;;
        esac
        shift
    done

    # Handle --check: requires --here
    if [[ "$CHECK" == true && "$HERE" == false ]]; then
        log_error "--check can only be used with --here"
        exit 1
    fi

    # Handle --from-scratch: requires --here
    if [[ "$FROM_SCRATCH" == true && "$HERE" == false ]]; then
        log_error "--from-scratch can only be used with --here"
        exit 1
    fi

    # --entry is only valid with --repo_file (default mode) or --here,
    # and is incompatible with --all, --check, and --from-scratch.
    if [[ -n "$ENTRY" ]]; then
        if [[ "$ALL" == true ]]; then
            log_error "--entry cannot be used with --all"
            exit 1
        fi
        if [[ "$CHECK" == true ]]; then
            log_error "--entry cannot be used with --check"
            exit 1
        fi
        if [[ "$FROM_SCRATCH" == true ]]; then
            log_error "--entry cannot be used with --from-scratch"
            exit 1
        fi
    fi

    # Handle --here: read AIRLAB_REPO_FILE from PWD and treat it as --repo_file
    if [[ "$HERE" == true ]]; then
        local marker_file="$PWD/AIRLAB_REPO_FILE"
        if [[ ! -f "$marker_file" ]]; then
            log_error "No AIRLAB_REPO_FILE found in current directory ($PWD)"
            exit 1
        fi
        REPO_NAME=$(cat "$marker_file")
        if [[ -z "$REPO_NAME" ]]; then
            log_error "AIRLAB_REPO_FILE is empty"
            exit 1
        fi
        log_info "Read repo file from AIRLAB_REPO_FILE: $REPO_NAME"

        local yaml_file="$AIRLAB_PATH/version_control/$REPO_NAME"
        [[ -e "$yaml_file" ]] || { log_error "YAML file not found: $yaml_file"; exit 1; }

        # If --check only, run the comparison and exit
        if [[ "$CHECK" == true && "$FROM_SCRATCH" == false ]]; then
            check_repositories "$PWD" "$yaml_file"
            exit $?
        fi

        # If --entry, run a partial init restricted to that single entry
        if [[ -n "$ENTRY" ]]; then
            process_repository "$PWD" "$yaml_file" "$ENTRY"
            exit 0
        fi

        # If --from-scratch, verify clean state, delete, and re-clone
        if [[ "$FROM_SCRATCH" == true ]]; then
            log_info "Running pre-flight check before --from-scratch..."
            if ! check_repositories "$PWD" "$yaml_file"; then
                log_error "Check found discrepancies (missing or extra folders)."
                log_error "Resolve them manually before using --from-scratch."
                exit 1
            fi

            log_warn "Deleting all repository folders defined in $REPO_NAME and re-cloning..."
            delete_yaml_repos "$PWD" "$yaml_file"

            log_info "Re-cloning repositories..."
            process_repository "$PWD" "$yaml_file"
            exit 0
        fi
    fi

    local yaml_dir="$AIRLAB_PATH/version_control"
    if [[ -z "$REPO_DIR" ]]; then
        log_info "Using 'dir' from YAML files as the target directory."
    else
        log_info "Overriding YAML 'dir' with user-specified path: $REPO_DIR"
    fi

    if [[ "$ALL" == true ]]; then
        log_info "Processing all repositories in YAML directory: $yaml_dir"
        process_all_repositories "$yaml_dir" "$REPO_DIR"
    else
        local yaml_file="$yaml_dir/$REPO_NAME"
        [[ -e "$yaml_file" ]] || { log_error "Specified YAML file not found: $yaml_file"; exit 1; }

        # Extract directory from YAML file or use provided path
        local yaml_dir_path
        yaml_dir_path=$(extract_yaml_dir "$yaml_file")
        local final_dir="${REPO_DIR:-$yaml_dir_path}"

        process_repository "$AIRLAB_PATH/$final_dir" "$yaml_file" "$ENTRY"
    fi
}

# Run main function
main "$@"
