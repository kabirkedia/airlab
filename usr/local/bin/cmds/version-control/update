#!/bin/bash

# Exit on error, undefined variables, and pipe failures
set -uo pipefail

# Color codes for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# Logging functions
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Function to print usage information
show_usage() {
    cat << EOF
Usage: airlab vcs update [OPTIONS]

Update repositories by pulling latest changes and initializing any new repos
from AIRLAB_REPO_FILE.

Steps:
  1. Pull all existing repos (stops on first failure).
  2. Run 'airlab vcs init --here' to clone any missing repos.
  3. Pull all repos again (collects failures and shows a summary).

Options:
  --help              Display this help message and exit

Examples:
  airlab vcs update

Note: Run this command from the directory containing AIRLAB_REPO_FILE.
EOF
}

parse_yaml() {
    local yaml_file=$1
    local key=$2
    local result

    if [[ ! -f "$yaml_file" ]]; then
        log_error "YAML file not found: $yaml_file"
        return 1
    fi

    if ! python3 -c "import yaml" 2>/dev/null; then
        log_error "Python YAML module not found. Please install: pip3 install PyYAML"
        return 1
    fi

    result=$(python3 -c '
import sys
import yaml

try:
    with open("'"$yaml_file"'", "r") as f:
        data = yaml.safe_load(f)
        value = data
        for key in "'"$key"'".split("."):
            if not isinstance(value, dict):
                print("")
                sys.exit(1)
            value = value.get(key, "")
        print(value)
except Exception as e:
    print("")
    sys.exit(1)
')

    if [[ -z "$result" ]]; then
        log_error "Failed to parse key '$key' from YAML file"
        return 1
    fi

    echo "$result"
}

# Extract the list of git repo paths from a YAML file
extract_git_repos() {
    local yaml_file=$1

    python3 - "$yaml_file" <<'PYEOF'
import sys, yaml

with open(sys.argv[1]) as f:
    data = yaml.safe_load(f)

for repo_path, info in sorted(data.get("repositories", {}).items()):
    if info.get("type") == "git":
        print(repo_path)
PYEOF
}

# Pull each git repo individually, stop on first failure.
# Returns 0 if all succeeded, 1 on first failure.
pull_stop_on_failure() {
    local base_dir=$1
    local yaml_file=$2

    local -a repo_list
    mapfile -t repo_list < <(extract_git_repos "$yaml_file")

    for repo_path in "${repo_list[@]}"; do
        local full_path="$base_dir/$repo_path"
        if [[ ! -d "$full_path/.git" ]]; then
            log_warn "Skipping $repo_path (not a git repo or missing)"
            continue
        fi

        log_info "Pulling $repo_path..."
        if ! git -C "$full_path" pull 2>&1; then
            log_error "Pull failed for $repo_path"
            return 1
        fi
    done

    return 0
}

# Pull each git repo individually, collect failures and print summary.
# Returns 0 if all succeeded, 1 if any failed.
pull_collect_failures() {
    local base_dir=$1
    local yaml_file=$2

    local -a repo_list
    mapfile -t repo_list < <(extract_git_repos "$yaml_file")

    local -a failed=()
    local -a succeeded=()

    for repo_path in "${repo_list[@]}"; do
        local full_path="$base_dir/$repo_path"
        if [[ ! -d "$full_path/.git" ]]; then
            log_warn "Skipping $repo_path (not a git repo or missing)"
            failed+=("$repo_path (missing)")
            continue
        fi

        log_info "Pulling $repo_path..."
        local pull_output
        if pull_output=$(git -C "$full_path" pull 2>&1); then
            succeeded+=("$repo_path")
        else
            log_error "Pull failed for $repo_path"
            echo "$pull_output"
            failed+=("$repo_path")
        fi
    done

    # Summary
    echo
    log_info "=== Pull Summary ==="
    if [[ ${#succeeded[@]} -gt 0 ]]; then
        echo -e "  ${GREEN}Succeeded (${#succeeded[@]}):${NC}"
        for r in "${succeeded[@]}"; do
            echo -e "    ${GREEN}✓${NC} $r"
        done
    fi
    if [[ ${#failed[@]} -gt 0 ]]; then
        echo -e "  ${RED}Failed (${#failed[@]}):${NC}"
        for r in "${failed[@]}"; do
            echo -e "    ${RED}✗${NC} $r"
        done
        return 1
    else
        echo -e "  ${GREEN}All repos pulled successfully.${NC}"
        return 0
    fi
}

main() {
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help)
                show_usage
                exit 0
                ;;
            *)
                log_error "Invalid option: $1"
                show_usage
                exit 1
                ;;
        esac
        shift
    done

    # Read AIRLAB_REPO_FILE from PWD
    local marker_file="$PWD/AIRLAB_REPO_FILE"
    if [[ ! -f "$marker_file" ]]; then
        log_error "No AIRLAB_REPO_FILE found in current directory ($PWD)"
        exit 1
    fi
    local repo_name
    repo_name=$(cat "$marker_file")
    if [[ -z "$repo_name" ]]; then
        log_error "AIRLAB_REPO_FILE is empty"
        exit 1
    fi

    local yaml_file="$AIRLAB_PATH/version_control/$repo_name"
    if [[ ! -e "$yaml_file" ]]; then
        log_error "YAML file not found: $yaml_file"
        exit 1
    fi

    # --- Step 1: Pull existing repos, stop on first failure ---
    echo
    log_info "=== Step 1: Pulling existing repositories ==="
    if ! pull_stop_on_failure "$PWD" "$yaml_file"; then
        log_error "Step 1 failed. Fix the issue above before continuing."
        exit 1
    fi
    log_info "Step 1 completed successfully."

    # --- Step 2: Init any missing repos via airlab vcs init --here ---
    echo
    log_info "=== Step 2: Initializing missing repositories (airlab vcs init --here) ==="
    if ! /usr/local/bin/cmds/version-control/init --here; then
        log_error "Step 2 failed (airlab vcs init --here)."
        exit 1
    fi
    log_info "Step 2 completed successfully."

    # --- Step 3: Pull all repos again, collect failures ---
    echo
    log_info "=== Step 3: Pulling all repositories (final sync) ==="
    pull_collect_failures "$PWD" "$yaml_file"
    local rc=$?

    echo
    if [[ $rc -eq 0 ]]; then
        log_info "Update completed successfully."
    else
        log_warn "Update completed with some failures (see summary above)."
    fi

    exit $rc
}

# Run main function
main "$@"
